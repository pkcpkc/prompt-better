{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Dataset Case Definition",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier for this test case."
    },
    "inputs": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      },
      "description": "Key-value mapping of input placeholders to values."
    },
    "history": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "role": {
            "type": "string",
            "enum": ["user", "assistant", "system"]
          },
          "content": {
            "type": "string"
          },
          "prompt_name": {
            "type": "string"
          },
          "inputs": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "template_override": {
            "type": "string"
          }
        },
        "required": ["role"]
      }
    }
  },
  "required": ["inputs"]
}
